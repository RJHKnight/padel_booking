# Copy this to .env and fill in your details for local testing
# NEVER commit .env to git

FLOW_EMAIL=your.email@example.com
FLOW_PASSWORD=yourpassword

# Time slot in 24h format, e.g. 20:00 for 8pm
TARGET_TIME=20:00

# Optional: preferred court name (leave blank to take any available)
COURT_PREF=

# How many days ahead to book (default 5)
DAYS_AHEAD=5

# Retry settings if slot isn't live yet at run time
MAX_RETRIES=12
RETRY_DELAY_S=15

# Set to "false" to watch the browser (useful for debugging locally)
HEADLESS=false
